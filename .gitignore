# =============================================================================
# Higher Ed Data Pipeline - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version
Pipfile.lock

# -----------------------------------------------------------------------------
# IDE and Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Data Files (Do not commit raw/processed data)
# -----------------------------------------------------------------------------
data/raw/*
data/staging/*
data/processed/*
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/processed/.gitkeep

# Large data files
*.csv
*.xlsx
*.xls
*.parquet
*.json
*.xml
*.gz
*.zip
*.tar
*.h5
*.hdf5
*.pkl
*.pickle

# Database files
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/*
!logs/.gitkeep
*.log

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.env
config/secrets.yaml
config/credentials.yaml
secrets/
credentials/

# AWS
.aws/

# GCP
*.json
!package.json
service-account*.json

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/_build/
site/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
